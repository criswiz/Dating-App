# Core
DATABASE_URL=sqlite:///./dev.db
SECRET_KEY=super-secret-change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS — comma-separated list of allowed origins
CORS_ALLOW_ORIGINS=http://localhost:8000,http://localhost:3000

# Base URL for building photo URLs returned to clients
BASE_URL=http://localhost:8000

# Directory to store uploaded photos (relative to backend/ or absolute)
UPLOADS_DIR=uploads

# AI feature gates (keep false until revenue/data thresholds are met)
AI_FEATURES_ENABLED=false
AI_GATE_APPROVED=false
AI_MIN_MONTHLY_REVENUE=2000
AI_MIN_TRAINING_EVENTS=10000
